---
import { getEntryBySlug } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const entries = await getCollection('dreams');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;
const entry = await getEntryBySlug('dreams', slug);

if (!entry) {
  throw new Error(`Dream entry not found for slug: ${slug}`);
}

const { Content } = await entry.render();
const { data } = entry;
---

<BaseLayout title={data.title} description={data.description}>
  <article class="dream-entry">
    <h1>{data.title}</h1>
    {data.date && <p class="dream-date">{data.date}</p>}
    <div class="dream-content">
      <Content />
    </div>
  </article>
</BaseLayout>
