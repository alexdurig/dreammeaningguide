
---
const {
  title = "Dream Meaning Guide",
  description = "Explore dream interpretations, symbolism, and spiritual insights."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Global Styles -->
    <style>
      :root {
        --purple: #6a4df5;
        --purple-light: #8d6bff;
        --bg-light: #faf8ff;
        --text-dark: #222;
        --max-width: 900px;
        --font-main: "Inter", sans-serif;
      }

      body {
        margin: 0;
        padding: 0;
        font-family: var(--font-main);
        background: var(--bg-light);
        color: var(--text-dark);
        line-height: 1.6;
      }

      header {
        background: var(--purple);
        padding: 1rem;
        text-align: center;
      }

      header a {
        color: white;
        text-decoration: none;
        font-weight: 600;
        margin: 0 1rem;
      }

      header nav {
        margin-top: 0.5rem;
      }

      main {
        max-width: var(--max-width);
        margin: 2rem auto;
        padding: 0 1rem;
      }

      footer {
        text-align: center;
        padding: 2rem 1rem;
        margin-top: 3rem;
        background: var(--purple-light);
        color: white;
      }

      footer a {
        color: white;
        text-decoration: underline;
      }
    </style>
  </head>

  <body>
    <header>
      <a href="/">Dream Meaning Guide</a>
    <nav>
  <a href="/">Home</a>
  <a href="/dreams">Dreams</a>
  <a href="/about">About</a>
  <a href="/contact">Contact</a>
</nav>

    </header>

    <main>
      <slot />
    </main>

  <!-- your page content -->

  <!-- FOOTER START -->
  <footer class="meaning-footer">
  <!-- FOOTER START -->
<footer class="meaning-footer">
  <div class="footer-brand">
    <span class="footer-logo">🌙</span>
    <span class="footer-brand-text">A Meaning Atlas Project</span>
  </div>

  <nav class="footer-nav">
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/privacy">Privacy Policy</a>
    <a href="/terms">Terms of Use</a>
    <a href="/sitemap">Sitemap</a>
  </nav>

  <div class="footer-seer">
    <span class="footer-seer-icon">🔮</span>
    <span>Guided by the Meaning Atlas Seer</span>
  </div>

  <div class="footer-copy">
    © 2026 The Meaning Atlas — All rights reserved
  </div>
</footer>
<!-- FOOTER END -->

  </body>
</html>
