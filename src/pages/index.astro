
---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="DreamMeaningGuide — Explore the Symbols of Your Dreams"
  description="Discover the hidden meanings behind your dreams. Explore symbols, archetypes, and the unconscious mind with DreamMeaningGuide.site."
>
  <style>
    .hero {
      text-align: center;
      padding: 6rem 2rem 4rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero-glyph {
      font-size: 5rem;
      display: block;
      margin-bottom: 1.5rem;
      filter: drop-shadow(0 0 32px rgba(167, 139, 250, 0.5));
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }
    h1 {
      font-family: 'Cinzel', serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      color: #d8c8ff;
      margin-bottom: 1.25rem;
      line-height: 1.2;
    }
    .tagline {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: #a78bfa;
      font-weight: 300;
      max-width: 600px;
      margin: 0 auto 3rem;
      line-height: 1.7;
    }
    .nav-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.25rem;
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 1.5rem 5rem;
    }
    .nav-card {
      background: rgba(45, 21, 84, 0.55);
      border: 1px solid rgba(167, 139, 250, 0.18);
      border-radius: 1.25rem;
      padding: 2rem 1.5rem;
      text-align: center;
      text-decoration: none;
      color: #e8e0ff;
      transition: all 0.22s ease;
      backdrop-filter: blur(12px);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
    .nav-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 0 40px rgba(139, 92, 246, 0.25);
      border-color: rgba(139, 92, 246, 0.4);
    }
    .card-icon { font-size: 2.5rem; }
    .card-title { font-family: 'Cinzel', serif; font-size: 1.1rem; color: #c4b5fd; }
    .card-desc { font-size: 0.85rem; color: #a78bfa; line-height: 1.6; }
  </style>

  <div class="hero">
    <span class="hero-glyph">✦</span>
    <h1>Explore the Symbols<br/>of Your Dreams</h1>
    <p class="tagline">
      Dreams carry meaning. DreamMeaningGuide helps you decode the symbols,
      archetypes, and patterns your unconscious mind leaves behind.
    </p>
  </div>

  <div class="nav-cards">
    <a href="/dream-symbols" class="nav-card">
      <span class="card-icon">🌀</span>
      <span class="card-title">Dream Symbols</span>
      <span class="card-desc">Browse animals, places, emotions, and archetypes and their deeper meanings.</span>
    </a>
    <a href="/seer" class="nav-card">
      <span class="card-icon">🔮</span>
      <span class="card-title">The Seer</span>
      <span class="card-desc">Ask a question and receive a symbolic answer from the oracle within.</span>
    </a>
    <a href="/journal" class="nav-card">
      <span class="card-icon">📖</span>
      <span class="card-title">Dream Journal</span>
      <span class="card-desc">Record your dreams, receive reflections, and build your personal archive.</span>
    </a>
    <a href="/sleep-tools-hub" class="nav-card">
      <span class="card-icon">🌙</span>
      <span class="card-title">Sleep Tools Hub</span>
      <span class="card-desc">Curated tools for deeper sleep, richer dreams, and meaningful rest.</span>
    </a>
    <a href="/about" class="nav-card">
      <span class="card-icon">✦</span>
      <span class="card-title">About</span>
      <span class="card-desc">Our mission and philosophy behind DreamMeaningGuide.site.</span>
    </a>
  </div>
</BaseLayout>


