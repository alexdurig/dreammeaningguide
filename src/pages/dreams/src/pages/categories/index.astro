---
import BaseLayout from "../../layouts/BaseLayout.astro";

const categories = [
  "Animals",
  "People",
  "Emotions",
  "Nature",
  "Objects",
  "Situations",
  "Nightmares",
  "Spiritual Dreams"
];
---

<BaseLayout title="Dream Categories" description="Browse dream meanings by theme.">
  <h1>Dream Categories</h1>
  <p>Select a category to explore related dream interpretations.</p>

  <ul>
    {categories.map(cat => (
      <li>
        <a href={`/categories/${cat.toLowerCase().replace(/ /g, "-")}`}>{cat}</a>
      </li>
    ))}
  </ul>

  <style>
    ul {
      list-style: none;
      padding: 0;
    }
    li {
      margin: 0.4rem 0;
    }
    a {
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>
</BaseLayout>
