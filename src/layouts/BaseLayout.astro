---
const {
  title = "Dream Meaning Guide",
  description = "Explore dream meanings, symbols, and interpretations."
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
