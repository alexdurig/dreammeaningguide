---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const dreams = Astro.glob("../*.md").filter(d => d.frontmatter.category === "nightmares");
---

<BaseLayout title="Nightmare Dreams">

  <section style="
    background: #6a4df5;
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    border-radius: 0 0 12px 12px;
  ">
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">
      😱 Nightmares
    </h1>
    <p style="font-size: 1.1rem; opacity: 0.9;">
      Nightmares highlight fear, avoidance, stress, and the need for emotional protection.
    </p>
  </section>

  <section style="max-width: 900px; margin: 3rem auto;">
    <ul style="list-style: none; padding: 0;">
      {dreams.map(d => (
        <li style="margin-bottom: 0.8rem;">
          <a href={`/dreams/${d.slug}`} style="
            text-decoration: none;
            color: #333;
            font-size: 1.1rem;
            padding: 0.6rem 0.4rem;
            display: block;
            border-bottom: 1px solid #eee;
          ">
            {d.frontmatter.title}
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>
