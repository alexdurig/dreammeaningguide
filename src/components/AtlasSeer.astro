---
let clarificationCount = 0;
---

<div style="max-width:700px; margin:2rem auto; padding:1.5rem;">
  <label for="seer-input" style="font-size:1rem; color:#444;">
    Describe your dream:
  </label>

  <textarea
    id="seer-input"
    rows="3"
    style="
      width:100%;
      margin-top:0.5rem;
      padding:0.75rem;
      border-radius:8px;
      border:1px solid #ccc;
      font-size:1rem;
      resize:vertical;
    "
    placeholder="I dreamed of a white owl flying over water..."
  ></textarea>

  <button
    id="seer-button"
    style="
      margin-top:0.75rem;
      padding:0.6rem 1.2rem;
      border-radius:6px;
      background:#6a4df5;
      color:white;
      border:none;
      cursor:pointer;
      font-size:1rem;
    "
  >
    Ask the Seer
  </button>

  <div id="seer-output" style="margin-top:1.5rem; min-height:2rem; color:#333; line-height:1.6;"></div>
</div>

<script>
  const dreamTriggers = [
    "dream", "dreamed", "dreamt", "nightmare", "vision",
    "i saw", "i was", "there was", "last night", "in the night", "i remember"
  ];

  const symbolMap = {
    owl: [
      "The Seer observes the owl as a keeper of hidden truths.",
      "The Seer senses the owl guiding you toward quiet intuition."
    ],
    water: [
      "The Seer feels water reflecting the tides of emotion.",
      "The Seer notes water as a mirror of your inner landscape."
    ],
    snake: [
      "The Seer reads the snake as a symbol of transformation.",
      "The Seer senses the snake shedding what no longer serves you."
    ],
    white: [
      "The Seer sees white as a sign of clarity and renewal.",
      "The Seer senses white as a quiet arrival of insight."
    ],
    dark: [
      "The Seer senses darkness as a veil over unspoken truths.",
      "The Seer observes the dark inviting gentle attention."
    ],
    flying: [
      "The Seer reads flying as a rise above what once felt heavy.",
      "The Seer senses flight as a movement toward freedom."
    ]
  };

  const closingLines = [
    "The Seer feels this dream nudging you toward a deeper truth.",
    "The Seer senses quiet change moving within you.",
    "The Seer reads your symbols as a soft call toward clarity."
  ];

  let clarificationCount = 0;

  function containsDreamContext(text) {
    const t = text.toLowerCase();
    return dreamTriggers.some(trigger => t.includes(trigger));
  }

  function extractSymbols(text) {
    const t = text.toLowerCase();
    return Object.keys(symbolMap).filter(symbol => t.includes(symbol));
  }

  function pick(arr) {
    return arr[Math.floor(Math.random() * arr.length)];
  }

  function interpret(text) {
    const output = [];

    const symbols = extractSymbols(text);

    if (!containsDreamContext(text) && symbols.length === 0) {
      return [
        "The Seer listens… but senses your question lies beyond the realm of dreams.",
        "Speak of symbols, visions, or the landscapes of sleep — and the Seer will answer."
      ];
    }

    if (symbols.length === 0) {
      clarificationCount++;

      if (clarificationCount === 1) {
        return [
          "The Seer hears your dream, but its symbols remain soft at the edges.",
          "Name one or two key images — a creature, a color, a place — and the Seer will look again."
        ];
      }

      if (clarificationCount >= 2) {
        return [
          "The Seer cannot see further into this dream.",
          "No answer rises at this time."
        ];
      }
    }

    clarificationCount = 0;

    output.push("The Seer senses a quiet pattern moving through your dream…");
    output.push(pick(symbolMap[symbols[0]]));

    if (symbols[1]) {
      output.push(pick(symbolMap[symbols[1]]));
    }

    output.push(pick(closingLines));

    return output.slice(0, 3);
  }

  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      const input = document.getElementById("seer-input");
      const button = document.getElementById("seer-button");
      const output = document.getElementById("seer-output");

      button.addEventListener("click", () => {
        const text = input.value.trim();
        const lines = interpret(text);

        output.innerHTML = "";
        lines.forEach(line => {
          const p = document.createElement("p");
          p.textContent = line;
          output.appendChild(p);
        });
      });
    });
  }
</script>

