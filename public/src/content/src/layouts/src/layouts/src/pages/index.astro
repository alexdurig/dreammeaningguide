---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Dream Meaning Guide" description="Clear meanings for every dream.">
  <h1>Welcome to Dream Meaning Guide</h1>
  <p>Your trusted source for clear, calm, expert dream interpretations.</p>

  <h2>Explore</h2>
  <ul>
    <li><a href="/dreams">A–Z Dream Dictionary</a></li>
    <li><a href="/categories">Browse by Category</a></li>
  </ul>

  <style>
    h1 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
    }
    h2 {
      margin-top: 2.5rem;
      font-size: 1.4rem;
    }
    ul {
      list-style: none;
      padding: 0;
    }
    li {
      margin: 0.5rem 0;
    }
    a {
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
    }
    a:hover {
      text-decoration: underline;
    }
  </style>
</BaseLayout>
