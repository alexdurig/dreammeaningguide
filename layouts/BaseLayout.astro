---
const { title = "Dream Meaning Guide", description = "Explore dream meanings, symbols, and interpretations." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Basic styling -->
    <style>

  /* Meaning Atlas Footer Styles */
.meaning-footer {
  margin-top: 4rem;
  padding: 3rem 1rem;
  background: #f8f8f8;
  color: #333;
  text-align: center;
  border-top: 1px solid #e0e0e0;
  font-size: 0.95rem;
}

.footer-brand {
  font-weight: 600;
  margin-bottom: 1rem;
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  align-items: center;
}

.footer-logo {
  font-size: 1.2rem;
}

.footer-nav {
  margin: 1rem 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.2rem;
}

.footer-nav a {
  color: #333;
  text-decoration: none;
  font-weight: 500;
}

.footer-nav a:hover {
  text-decoration: underline;
}

.footer-seer {
  margin-top: 1.5rem;
  font-style: italic;
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  align-items: center;
  color: #444;
}

.footer-seer-icon {
  font-size: 1.1rem;
}

.footer-copy {
  margin-top: 1.5rem;
  color: #666;
  font-size: 0.85rem;
}

   
</style>
  </head>

  <body>
    <header>
      <h1>Dream Meaning Guide</h1>
    </header>

    <main>
      <slot />
    </main>

  /* Meaning Atlas Footer Styles */
  .meaning-footer {
    margin-top: 4rem;
    padding: 3rem 1rem;
    background: #f8f8f8;
    color: #333;
    text-align: center;
    border-top: 1px solid #e0e0e0;
    font-size: 0.95rem;
  }

  .footer-brand {
    font-weight: 600;
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    align-items: center;
  }

  .footer-logo {
    font-size: 1.2rem;
  }

  .footer-nav {
    margin: 1rem 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.2rem;
  }

  .footer-nav a {
    color: #333;
    text-decoration: none;
    font-weight: 500;
  }

  .footer-nav a:hover {
    text-decoration: underline;
  }

  .footer-seer {
    margin-top: 1.5rem;
    font-style: italic;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    align-items: center;
    color: #444;
  }

  .footer-seer-icon {
    font-size: 1.1rem;
  }

  .footer-copy {
    margin-top: 1.5rem;
    color: #666;
    font-size: 0.85rem;
  }

  </body>
</html>
