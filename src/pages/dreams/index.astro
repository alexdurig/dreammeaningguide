---
import Layout from "../../layouts/BaseLayout.astro";

// Later, when you add dream posts to src/content/dreams,
// Astro will automatically make them available here.
import { getCollection } from "astro:content";
const dreams = await getCollection("dreams");
---

<Layout title="A–Z Dream Dictionary" description="Browse clear, calm interpretations for every dream topic.">
  <section class="dictionary">
    <h1>A–Z Dream Dictionary</h1>
    <p>Browse clear, calm interpretations for every dream topic.</p>

    <ul class="dream-list">
      {dreams
        .sort((a, b) => a.data.title.localeCompare(b.data.title))
        .map((dream) => (
          <li>
            <a href={`/dreams/${dream.slug}/`}>{dream.data.title}</a>
          </li>
        ))}
    </ul>
  </section>

  <style>
    .dictionary {
      text-align: center;
      padding: 2rem 1rem;
    }

    .dream-list {
      list-style: none;
      padding: 0;
      margin-top: 2rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .dream-list li {
      margin: 0.5rem 0;
    }

    .dream-list a {
      color: var(--purple);
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</Layout>



