
---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const pageTitle = "Dream Symbols | DreamMeaningGuide";
const pageDescription = "Explore symbolic meanings behind common dream symbols — animals, places, emotions, and archetypes.";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <link rel="canonical" href="https://dreammeaningguide.site/dream-symbols" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body { background: radial-gradient(circle at top, #2b0f4a, #0f0a1a); color: #e8e0ff; font-family: Inter, sans-serif; margin: 0; padding: 0; }
    main { max-width: 900px; margin: 0 auto; padding: 2rem; }
    h1 { font-family: Cinzel, serif; font-size: 2.6rem; text-align: center; color: #d8c8ff; margin-bottom: 1rem; }
    .search-box { text-align: center; margin: 2rem 0; }
    input { width: 80%; padding: 0.8rem; border-radius: 6px; border: 1px solid #6a4bcf; background: #1a1330; color: #e8e0ff; font-size: 1rem; }
    .symbol-category { margin-top: 2rem; }
    .symbol-category h2 { font-family: Cinzel, serif; font-size: 1.6rem; color: #cbb4ff; border-bottom: 1px solid #6a4bcf; padding-bottom: 0.3rem; margin-bottom: 1rem; }
    .symbol-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
    .symbol-item { background: #1a1330; border: 1px solid #6a4bcf; padding: 1rem; border-radius: 8px; text-align: center; transition: transform 0.3s ease, background 0.3s ease; cursor: pointer; }
    .symbol-item:hover { transform: scale(1.05); background: #2b1a55; }
  </style>
</head>
<body>
  <SiteNav />
  <main>
    <h1>Dream Symbols</h1>
    <div class="search-box">
      <input id="symbol-search" type="text" placeholder="Search symbols..." oninput="filterSymbols()" />
    </div>
    <div id="symbols-container">
      <div class="symbol-category">
        <h2>Animals</h2>
        <div class="symbol-list">
          <div class="symbol-item">Snake</div>
          <div class="symbol-item">Wolf</div>
          <div class="symbol-item">Bird</div>
          <div class="symbol-item">Cat</div>
          <div class="symbol-item">Horse</div>
        </div>
      </div>
      <div class="symbol-category">
        <h2>Places</h2>
        <div class="symbol-list">
          <div class="symbol-item">Forest</div>
          <div class="symbol-item">Ocean</div>
          <div class="symbol-item">Bridge</div>
          <div class="symbol-item">Mountain</div>
          <div class="symbol-item">City</div>
        </div>
      </div>
      <div class="symbol-category">
        <h2>Emotions</h2>
        <div class="symbol-list">
          <div class="symbol-item">Fear</div>
          <div class="symbol-item">Joy</div>
          <div class="symbol-item">Confusion</div>
          <div class="symbol-item">Longing</div>
          <div class="symbol-item">Peace</div>
        </div>
      </div>
      <div class="symbol-category">
        <h2>Archetypes</h2>
        <div class="symbol-list">
          <div class="symbol-item">Shadow</div>
          <div class="symbol-item">Guide</div>
          <div class="symbol-item">Child</div>
          <div class="symbol-item">Warrior</div>
          <div class="symbol-item">Seer</div>
        </div>
      </div>
    </div>
  </main>
  <SiteFooter />
  <script>
    function filterSymbols() {
      const query = document.getElementById("symbol-search").value.toLowerCase();
      const items = document.querySelectorAll(".symbol-item");
      items.forEach(item => {
        const text = item.textContent.toLowerCase();
        item.style.display = text.includes(query) ? "block" : "none";
      });
    }
  </script>
</body>
</html>


