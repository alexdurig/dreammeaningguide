
---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const pageTitle = "Dream Journal | DreamMeaningGuide";
const pageDescription = "Record your dreams, explore symbolic reflections, and revisit your dream archive.";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <link rel="canonical" href="https://dreammeaningguide.site/journal" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body { background: radial-gradient(circle at top, #2b0f4a, #0f0a1a); color: #e8e0ff; font-family: Inter, sans-serif; margin: 0; padding: 0; }
    main { max-width: 900px; margin: 0 auto; padding: 2rem; }
    h1 { font-family: Cinzel, serif; font-size: 2.6rem; text-align: center; color: #d8c8ff; margin-bottom: 1rem; }
    h2 { font-family: Cinzel, serif; font-size: 1.8rem; color: #cbb4ff; margin-top: 2rem; border-bottom: 1px solid #6a4bcf; padding-bottom: 0.3rem; }
    input, textarea { width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #6a4bcf; background: #1a1330; color: #e8e0ff; font-size: 1rem; margin-top: 0.5rem; }
    textarea { height: 200px; }
    button { margin-top: 1rem; padding: 0.7rem 1.4rem; background: #7c3aed; border: none; border-radius: 6px; color: white; font-size: 1rem; cursor: pointer; transition: background 0.3s ease; }
    button:hover { background: #9d5bff; }
    .entry-card { background: #1a1330; border: 1px solid #6a4bcf; padding: 1rem; border-radius: 8px; margin-bottom: 1rem; cursor: pointer; transition: transform 0.3s ease, background 0.3s ease; }
    .entry-card:hover { transform: scale(1.03); background: #2b1a55; }
    .archive-list { max-height: 300px; overflow-y: auto; margin-top: 1rem; padding-right: 0.5rem; }
    .reflection-box { margin-top: 1rem; padding: 1rem; background: #1a1330; border: 1px solid #6a4bcf; border-radius: 8px; font-family: Cinzel, serif; font-size: 1.2rem; opacity: 0; transition: opacity 1.5s ease; }
    .full-entry-view { margin-top: 2rem; padding: 1.5rem; background: #1a1330; border: 1px solid #6a4bcf; border-radius: 8px; display: none; }
    .back-button { margin-top: 1rem; background: #6a4bcf; }
  </style>
</head>
<body>
  <SiteNav />
  <main>
    <h1>Dream Journal</h1>
    <h2>Write a New Dream</h2>
    <label>Title (optional)</label>
    <input id="entry-title" type="text" placeholder="Dream title..." />
    <label>Tags (optional)</label>
    <input id="entry-tags" type="text" placeholder="e.g., flying, ocean, shadow..." />
    <label>Your Dream</label>
    <textarea id="entry-text" placeholder="Write your dream here..."></textarea>
    <button onclick="saveEntry()">Save Dream Entry</button>
    <div id="reflection" class="reflection-box"></div>
    <h2>Your Dream Archive</h2>
    <div id="archive-list" class="archive-list"></div>
    <div id="full-entry-view" class="full-entry-view">
      <h2 id="full-entry-title"></h2>
      <p><strong>Date:</strong> <span id="full-entry-date"></span></p>
      <p><strong>Tags:</strong> <span id="full-entry-tags"></span></p>
      <p id="full-entry-text"></p>
      <p><strong>Seer's Reflection:</strong></p>
      <p id="full-entry-reflection"></p>
      <button class="back-button" onclick="closeFullEntry()">Back to Archive</button>
    </div>
  </main>
  <SiteFooter />
  <script>
    const reflections = [
      "The Seer senses a quiet truth beneath your dream.",
      "Your dream carries a symbol that wants your attention.",
      "There is a pattern forming across your recent dreams.",
      "Your dream is pointing toward an inner threshold.",
      "The Seer sees a transformation beginning within you.",
      "Your dream is whispering a message about your next step.",
      "The Seer feels a subtle shift in your inner landscape.",
      "Your dream reveals something ready to be understood."
    ];
    function loadArchive() {
      const archive = JSON.parse(localStorage.getItem("dreamJournalArchive") || "[]");
      const list = document.getElementById("archive-list");
      list.innerHTML = "";
      archive.forEach((entry, index) => {
        const card = document.createElement("div");
        card.className = "entry-card";
        card.onclick = () => openFullEntry(index);
        card.innerHTML = `<strong>${entry.title || "Untitled Dream"}</strong><br><em>${entry.date}</em><br><span>${entry.text.substring(0, 80)}...</span>`;
        list.appendChild(card);
      });
    }
    function saveEntry() {
      const title = document.getElementById("entry-title").value.trim();
      const tags = document.getElementById("entry-tags").value.trim();
      const text = document.getElementById("entry-text").value.trim();
      const reflectionBox = document.getElementById("reflection");
      if (!text) return;
      const dateString = new Date().toLocaleString();
      const reflection = reflections[Math.floor(Math.random() * reflections.length)];
      const newEntry = { title, tags, text, reflection, date: dateString };
      const archive = JSON.parse(localStorage.getItem("dreamJournalArchive") || "[]");
      archive.unshift(newEntry);
      localStorage.setItem("dreamJournalArchive", JSON.stringify(archive));
      reflectionBox.textContent = reflection;
      reflectionBox.style.opacity = "1";
      document.getElementById("entry-title").value = "";
      document.getElementById("entry-tags").value = "";
      document.getElementById("entry-text").value = "";
      loadArchive();
    }
    function openFullEntry(index) {
      const archive = JSON.parse(localStorage.getItem("dreamJournalArchive") || "[]");
      const entry = archive[index];
      document.getElementById("full-entry-title").textContent = entry.title || "Untitled Dream";
      document.getElementById("full-entry-date").textContent = entry.date;
      document.getElementById("full-entry-tags").textContent = entry.tags || "None";
      document.getElementById("full-entry-text").textContent = entry.text;
      document.getElementById("full-entry-reflection").textContent = entry.reflection;
      document.getElementById("full-entry-view").style.display = "block";
      document.getElementById("archive-list").style.display = "none";
    }
    function closeFullEntry() {
      document.getElementById("full-entry-view").style.display = "none";
      document.getElementById("archive-list").style.display = "block";
    }
    window.onload = loadArchive;
  </script>
</body>
</html>


