---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SYMBOLS } from '../../data/symbols.js';
export async function getStaticPaths() {
  return SYMBOLS.map((s) => ({ params: { slug: s.slug }, props: { symbol: s } }));
}
const { symbol } = Astro.props;
const term = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": symbol.name + " Dream Symbol",
  "description": symbol.description,
  "inDefinedTermSet": { "@type": "DefinedTermSet", "name": "Dream Symbol Dictionary", "url": String(Astro.site) + "dream-symbols" },
  "url": String(Astro.url)
};
const bc = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": Astro.site },
    { "@type": "ListItem", "position": 2, "name": "Dream Symbols", "item": String(Astro.site) + "dream-symbols" },
    { "@type": "ListItem", "position": 3, "name": symbol.name, "item": String(Astro.url) }
  ]
};
---
<BaseLayout
  title={symbol.name + " Dream Meaning - Symbols, Archetypes and Interpretations"}
  description={"What does dreaming of a " + symbol.name.toLowerCase() + " mean? " + symbol.tagline + ". Explore the symbolic, psychological, and archetypal meanings."}
  schema={[term, bc]}
>
  <nav aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href="/dream-symbols">Dream Symbols</a></li>
      <li aria-current="page">{symbol.name}</li>
    </ol>
  </nav>
  <article>
    <header>
      <p class="category">{symbol.category}</p>
      <h1>{symbol.name} Dream Meaning</h1>
      <p class="tagline">{symbol.tagline}</p>
    </header>
    <section class="overview">
      <h2>What Does It Mean to Dream of a {symbol.name}?</h2>
      <p>{symbol.description}</p>
    </section>
    <section class="meanings">
      <h2>Core Symbolic Meanings</h2>
      <ul>{symbol.meanings.map((m) => <li>{m}</li>)}</ul>
    </section>
    <section class="related">
      <h2>Related Dream Symbols</h2>
      <ul>{symbol.related.map((s) => <li><a href={"/dream-symbols/" + s}>{s.charAt(0).toUpperCase() + s.slice(1)}</a></li>)}</ul>
    </section>
  </article>
</BaseLayout>

