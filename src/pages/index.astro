import Layout from '../layouts/BaseLayout.astro';

// Load all Markdown files in this folder
const posts = import.meta.glob('./*.md', { eager: true });

// Convert object keys to an array of URLs
const entries = Object.keys(posts)
  .map((path) => {
    const url = path
      .replace('./', '/dreams/')
      .replace('.md', '/');
    return { url };
  })
  .sort((a, b) => a.url.localeCompare(b.url));
---

<Layout title="A–Z Dream Dictionary">
  <h1>A–Z Dream Dictionary</h1>
  <p>Browse clear, calm interpretations for every dream topic.</p>

  <ul>
    {entries.map((entry) => (
      <li>
        <a href={entry.url}>
          {entry.url
            .split('/')
            .filter(Boolean)
            .pop()
            .replace(/-/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase())}
        </a>
      </li>
    ))}
  </ul>
</Layout>
