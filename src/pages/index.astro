---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Alphabet letters for navigation
const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
---

<BaseLayout title="A–Z Dream Dictionary">

  <!-- HEADER -->
  <section style="
    background: #6a4df5;
    color: white;
    padding: 3rem 1rem;
    text-align: center;
    border-radius: 0 0 12px 12px;
  ">
    <h1 style="font-size: 2.2rem; margin-bottom: 0.5rem;">
      A–Z Dream Dictionary
    </h1>
    <p style="font-size: 1.1rem; opacity: 0.9;">
      Browse dream meanings alphabetically — fast, simple, intuitive.
    </p>
  </section>

  <!-- ALPHABET NAVIGATION -->
  <section style="max-width: 900px; margin: 2.5rem auto; text-align: center;">
    <div style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(40px, 1fr));
      gap: 0.5rem;
    ">
      {letters.map(letter => (
        <a 
          href={`/dreams?letter=${letter}`} 
          style="
            display: block;
            padding: 0.8rem;
            background: #f7f5ff;
            border-radius: 6px;
            text-decoration: none;
            color: #6a4df5;
            font-weight: 700;
            font-size: 1.1rem;
          "
        >
          {letter}
        </a>
      ))}
    </div>
  </section>

  <!-- DREAM LIST -->
  <section style="max-width: 900px; margin: 3rem auto;">
    <h2 style="font-size: 1.6rem; margin-bottom: 1rem; text-align: center;">
      All Dream Interpretations
    </h2>

    <ul style="list-style: none; padding: 0; margin: 0;">
     
          <li style="margin-bottom: 0.8rem;">
            <a 
              href={`/dreams/${dream.slug}`} 
              style="
                text-decoration: none;
                color: #333;
                font-size: 1.1rem;
                padding: 0.6rem 0.4rem;
                display: block;
                border-bottom: 1px solid #eee;
              "
            >
              {dream.frontmatter.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

</BaseLayout>



