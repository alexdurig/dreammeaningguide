---
const { title = "Dream Meaning Guide", description = "Clear meanings for every dream." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- Global Styles -->
    <style>
      body {
        font-family: 'Inter', sans-serif;
        margin: 0;
        padding: 0;
        background: #fafafa;
        color: #222;
      }
      header {
        padding: 1.5rem;
        background: #ffffff;
        border-bottom: 1px solid #eee;
      }
      nav a {
        margin-right: 1rem;
        text-decoration: none;
        color: #444;
        font-weight: 600;
      }
      nav a:hover {
        color: #000;
      }
      main {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      footer {
        margin-top: 4rem;
        padding: 2rem;
        text-align: center;
        color: #777;
        font-size: 0.9rem;
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/dreams">Dream Dictionary</a>
        <a href="/categories">Categories</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      DreamMeaningGuide.site — Clear meanings for every dream.
    </footer>
  </body>
</html>
