---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';

// Load all dream entries from the content collection
const entries = await getCollection('dreams');

// Normalize titles for alphabetization
function normalizeTitle(title) {
  let t = title.toLowerCase();
  if (t.startsWith("dream about a ")) return t.replace("dream about a ", "");
  if (t.startsWith("dream about ")) return t.replace("dream about ", "");
  return t;
}

// Convert to array of { slug, title, normalized }
const dreams = entries.map(entry => ({
  slug: entry.slug,
  title: entry.data.title,
  normalized: normalizeTitle(entry.data.title)
}));

// Group dreams by first letter of normalized title
const grouped = dreams.reduce((acc, dream) => {
  const letter = dream.normalized[0].toUpperCase();
  acc[letter] = acc[letter] || [];
  acc[letter].push(dream);
  return acc;
}, {});
---

<Layout title="A–Z Dream Dictionary">

  <section class="dictionary">
    <h1>A–Z Dream Dictionary</h1>
    <p>Browse dream meanings alphabetically.</p>

    <div style="max-width: 600px; margin: 2rem auto;">
      <input
        type="text"
        id="search-input"
        placeholder="Search dream meanings..."
        style="
          width: 100%;
          padding: 0.9rem 1rem;
          border-radius: 0.5rem;
          border: 1px solid #ccc;
          font-size: 1.1rem;
        "
      />

      <ul id="search-results" style="margin-top: 1rem; list-style: none; padding: 0; display: none;">
      </ul>
    </div>

    <!-- A–Z Navigation Bar -->
    <nav class="az-nav">
      <ul>
        {Array.from({ length: 26 }, (_, i) => String.fromCharCode(65 + i)).map(letter => (
          <li><a href={`#${letter}`}>{letter}</a></li>
        ))}
      </ul>
    </nav>

    <style>
      .az-nav {
        margin: 2rem 0;
        text-align: center;
      }

      .az-nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
      }

      .az-nav a {
        display: inline-block;
        padding: 0.4rem 0.7rem;
        border-radius: 6px;
        background: #f2ebff;
        color: #5a2ca0;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.15s ease, color 0.15s ease;
      }

      .az-nav a:hover {
        background: #6a4df5;
        color: white;
      }
    </style>

    <!-- Dream Groups -->
    {Object.keys(grouped)
      .sort()
      .map((letter) => (
        <section id={letter} class="letter-group">
          <h2>{letter}</h2>
          <ul>
            {grouped[letter]
              .sort((a, b) => a.normalized.localeCompare(b.normalized))
              .map((dream) => (
                <li>
                  <a href={`/dreams/${dream.slug}/`}>{dream.title}</a>
                </li>
              ))}
          </ul>
        </section>
      ))}
  </section>

  <style>
    .dictionary {
      padding: 2rem 1rem;
      max-width: 800px;
      margin: 0 auto;
    }

    .letter-group {
      margin-top: 2.5rem;
    }

    .letter-group h2 {
      font-size: 1.6rem;
      color: #5a2ca0;
      margin-bottom: 0.5rem;
    }

    ul {
      list-style: none;
      padding: 0;
    }

    li {
      margin: 0.3rem 0;
    }

    a {
      color: #6a4df5;
      text-decoration: none;
      font-weight: 500;
    }

    a:hover {
      text-decoration: underline;
    }
  </style>

<script>
  const dreams = JSON.parse(`{
    "items": ${JSON.stringify(dreams)}
  }`).items;

  const input = document.getElementById("search-input");
  const results = document.getElementById("search-results");
  const letterGroups = document.querySelectorAll(".letter-group");
  const azNav = document.querySelector(".az-nav");

  function normalize(text) {
    let t = text.toLowerCase();
    if (t.startsWith("dream about a ")) return t.replace("dream about a ", "");
    if (t.startsWith("dream about ")) return t.replace("dream about ", "");
    return t;
  }

  input.addEventListener("input", () => {
    const query = input.value.trim().toLowerCase();

    if (query === "") {
      results.style.display = "none";
      results.innerHTML = "";
      letterGroups.forEach(g => g.style.display = "");
      azNav.style.display = "";
      return;
    }

    // Hide A–Z sections while searching
    letterGroups.forEach(g => g.style.display = "none");
    azNav.style.display = "none";

    const matches = dreams.filter(d =>
      normalize(d.title).includes(query)
    );

    results.innerHTML = matches
      .map(d => `<li><a href="/dreams/${d.slug}/">${d.title}</a></li>`)
      .join("");

    results.style.display = matches.length ? "block" : "none";
  });
</script>

</Layout>




